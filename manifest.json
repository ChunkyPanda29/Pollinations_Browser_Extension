{
  "manifest_version": 3,
  "name": "Pollinations Extension",
  "version": "1.0.5",
  "permissions": [
    "storage",
    "contextMenus",
    "declarativeNetRequest",
    "activeTab",
    "downloads",
    "identity" 
  ],
  "host_permissions": [
    "https://*.pollinations.ai/*"
  ],
  "declarative_net_request": {
    "rule_resources":[{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}